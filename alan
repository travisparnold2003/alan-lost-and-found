#!/usr/bin/env bash
set -euo pipefail

root_dir="$(cd "$(dirname "$0")" && pwd)"

resolve_tool() {
  local relative_path="$1"

  if [[ -x "$root_dir/.alan/$relative_path" ]]; then
    echo "$root_dir/.alan/$relative_path"
    return 0
  fi

  if [[ -x "$root_dir/src/.alan/$relative_path" ]]; then
    echo "$root_dir/src/.alan/$relative_path"
    return 0
  fi

  if [[ -x "$root_dir/src/.alan/$relative_path.exe" ]]; then
    echo "$root_dir/src/.alan/$relative_path.exe"
    return 0
  fi

  return 1
}

cmd="${1:-}"
shift || true

case "$cmd" in
  fetch)
    tool="$(resolve_tool "alan-tools/fetch")" || {
      echo "Could not find a runnable fetch tool in .alan or src/.alan" >&2
      exit 1
    }
    if "$tool" --versions "$root_dir/versions.json" default "$@"; then
      exit 0
    fi

    # Keep deploy.sh usable when fetch endpoint is flaky but tools already exist.
    if resolve_tool "devenv/platform/project-build-environment/tools/build-system" >/dev/null; then
      echo "Fetch failed, but existing .alan toolchain is present. Continuing with cached tools." >&2
      exit 0
    fi

    exit 1
    ;;
  build)
    tool="$(resolve_tool "devenv/platform/project-build-environment/tools/build-system")" || {
      echo "Could not find a runnable build tool in .alan or src/.alan" >&2
      exit 1
    }
    if [[ $# -eq 0 ]]; then
      exec "$tool" "$root_dir/dist/project.pkg"
    fi
    exec "$tool" "$@"
    ;;
  package)
    tool="$(resolve_tool "devenv/platform/project-build-environment/tools/deploy-system")" || {
      echo "Could not find a runnable package tool in .alan or src/.alan" >&2
      exit 1
    }
    exec "$tool" "$@"
    ;;
  connect)
    tool="$(resolve_tool "alan-tools/application-client")" || {
      echo "Could not find a runnable application client in .alan or src/.alan" >&2
      exit 1
    }
    exec "$tool" "$@"
    ;;
  deploy)
    tool="$(resolve_tool "devenv/platform/project-build-environment/tools/deploy-system")" || {
      echo "Could not find a runnable deploy tool in .alan or src/.alan" >&2
      exit 1
    }
    exec "$tool" "$@"
    ;;
  *)
    echo "Usage: alan {fetch|build|package|connect|deploy} [args...]" >&2
    exit 1
    ;;
esac
